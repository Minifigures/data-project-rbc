        <mxCell id="awsnote" value="Region ca-central-1 &#183; least-privilege IAM role &#183; tagged project=claimguard.&#10;Same handler runs locally on LocalStack via AWS_ENDPOINT_URL=http://localhost:4566" style="text;html=1;align=left;fontColor=#334155;fontSize=11;" vertex="1" parent="1"><mxGeometry x="930" y="306" width="546" height="46" as="geometry"/></mxCell>
        <mxCell id="awsref" value="Reference architecture: this slice was deployed and verified end-to-end (scorer to DynamoDB audit item + processed output), then fully torn down. Nothing is currently running." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F1F5F9;strokeColor=#CBD5E1;fontColor=#475569;fontSize=11;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;" vertex="1" parent="1"><mxGeometry x="930" y="378" width="546" height="100" as="geometry"/></mxCell>

        <mxCell id="legend" value="Legend&#10;&#10;Navy thick arrow = authoritative deterministic score (rule engine)&#10;Blue arrow = advisory ML signal (Isolation Forest, supervised)&#10;Dashed arrow = out-of-score LLM (rationale only, never scores)&#10;Grey arrow = pipeline data flow&#10;Navy fill = core / authoritative component" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FBFCFE;strokeColor=#CBD5E1;fontColor=#334155;fontSize=12;align=left;verticalAlign=top;spacingLeft=12;spacingTop=8;" vertex="1" parent="1"><mxGeometry x="910" y="520" width="578" height="196" as="geometry"/></mxCell>
        <mxCell id="privacy" value="Privacy is structural, not a policy&#10;&#10;The claim schema has no field for a name, address, or date of birth. It cannot leak what it cannot store. The deterministic rule score is the auditable floor; ML and the LLM never override it." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F0FB;strokeColor=#0B2545;fontColor=#334155;fontSize=12;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;" vertex="1" parent="1"><mxGeometry x="910" y="736" width="578" height="120" as="geometry"/></mxCell>

