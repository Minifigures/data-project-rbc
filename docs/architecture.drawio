        <mxCell id="review" value="Human review&#10;approve / flag / dismiss" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#1463B0;fontColor=#0B2545;fontSize=12;" vertex="1" parent="1"><mxGeometry x="72" y="908" width="176" height="72" as="geometry"/></mxCell>
        <mxCell id="audit" value="Immutable audit log&#10;hash-chained &#183; no PII &#183; tamper-evident" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#0B2545;strokeWidth=2;fontColor=#0B2545;fontSize=12;" vertex="1" parent="1"><mxGeometry x="272" y="908" width="176" height="72" as="geometry"/></mxCell>
