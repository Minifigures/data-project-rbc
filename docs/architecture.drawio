        <mxCell id="scorer" value="Scorer&#10;rules = authoritative score &#183; ML = advisory signals&#10;bands: auto-pass / review / priority-investigate" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F0FB;strokeColor=#0B2545;strokeWidth=2;fontColor=#0B2545;fontSize=12;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="265" y="790" width="360" height="74" as="geometry"/></mxCell>
        <mxCell id="lblL6" value="6 &#183; OUTPUTS, GOVERNANCE &amp; HUMAN-IN-THE-LOOP" style="text;html=1;fontColor=#1463B0;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="60" y="884" width="380" height="18" as="geometry"/></mxCell>
