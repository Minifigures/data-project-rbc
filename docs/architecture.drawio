<mxfile host="app.diagrams.net" type="device">
  <diagram name="ClaimGuard architecture">
    <mxGraphModel dx="1520" dy="1210" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1520" pageHeight="1210" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="title" value="ClaimGuard" style="text;html=1;align=left;fontColor=#0B2545;fontSize=28;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="40" y="18" width="300" height="40" as="geometry"/></mxCell>
        <mxCell id="subtitle" value="Auditable, explainable insurance-claim fraud detection, PII-free by design" style="text;html=1;align=left;fontColor=#475569;fontSize=13;" vertex="1" parent="1"><mxGeometry x="40" y="60" width="820" height="20" as="geometry"/></mxCell>
        <mxCell id="frame1" value="FRAME 1 &#183; LOGICAL PIPELINE" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#CBD5E1;verticalAlign=top;align=left;fontColor=#0B2545;fontStyle=1;fontSize=12;spacingLeft=12;spacingTop=8;" vertex="1" parent="1"><mxGeometry x="30" y="108" width="850" height="1090" as="geometry"/></mxCell>
        <mxCell id="lblL1" value="1 &#183; DATA SOURCES (PII-free)" style="text;html=1;fontColor=#1463B0;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="60" y="150" width="320" height="18" as="geometry"/></mxCell>
        <mxCell id="syn" value="Synthetic generator&#10;injected, labelled fraud &#183; zero PII" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#1463B0;fontColor=#0B2545;fontSize=12;" vertex="1" parent="1"><mxGeometry x="90" y="176" width="330" height="64" as="geometry"/></mxCell>
        <mxCell id="open" value="Open dataset loader&#10;Kaggle Medicare set &#183; auto-fallback to synthetic" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#1463B0;fontColor=#0B2545;fontSize=12;" vertex="1" parent="1"><mxGeometry x="470" y="176" width="330" height="64" as="geometry"/></mxCell>
        <mxCell id="pill" value="One canonical claim schema &#183; no name / address / DOB fields" style="rounded=1;arcSize=40;whiteSpace=wrap;html=1;fillColor=#E8F0FB;strokeColor=#1463B0;fontColor=#0B2545;fontSize=12;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="245" y="262" width="400" height="40" as="geometry"/></mxCell>
        <mxCell id="lblL2" value="2 &#183; INGESTION, VALIDATION &amp; PREPROCESSING" style="text;html=1;fontColor=#1463B0;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="60" y="322" width="360" height="18" as="geometry"/></mxCell>
        <mxCell id="validate" value="Validate, clean &amp; preprocess&#10;schema + quality gate &#183; dedupe &#183; handle missing&#10;coerce types &#183; encode categoricals" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#1463B0;fontColor=#0B2545;fontSize=12;" vertex="1" parent="1"><mxGeometry x="272" y="350" width="346" height="84" as="geometry"/></mxCell>
        <mxCell id="lblL3" value="3 &#183; FEATURE ENGINEERING" style="text;html=1;fontColor=#1463B0;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="60" y="446" width="240" height="18" as="geometry"/></mxCell>
        <mxCell id="features" value="Feature engineering&#10;within-code z-scores &#183; provider aggregates &#183; ratios&#10;shared by rules and ML (identical inputs)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#1463B0;fontColor=#0B2545;fontSize=12;" vertex="1" parent="1"><mxGeometry x="265" y="466" width="360" height="78" as="geometry"/></mxCell>
        <mxCell id="lblL4" value="4 &#183; DETECTION" style="text;html=1;fontColor=#1463B0;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="60" y="560" width="200" height="18" as="geometry"/></mxCell>
        <mxCell id="rules" value="Deterministic rule engine&#10;YAML policy &#183; NHCAA fraud typologies&#10;0 to 100 score &#183; expert-tunable&#10;AUTHORITATIVE &#183; auditable" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0B2545;strokeColor=#0B2545;fontColor=#FFFFFF;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="72" y="584" width="230" height="100" as="geometry"/></mxCell>
        <mxCell id="iforest" value="Isolation Forest&#10;unsupervised &#183; no labels&#10;advisory signal" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#1463B0;fontColor=#0B2545;fontSize=12;" vertex="1" parent="1"><mxGeometry x="330" y="584" width="230" height="100" as="geometry"/></mxCell>
        <mxCell id="supervised" value="Supervised model&#10;logistic / gradient boosting&#10;advisory signal" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#1463B0;fontColor=#0B2545;fontSize=12;" vertex="1" parent="1"><mxGeometry x="582" y="584" width="232" height="100" as="geometry"/></mxCell>
        <mxCell id="llm" value="Optional LLM layer&#10;field extraction + rationale &#183; OUT of score" style="rounded=1;dashed=1;whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#64748B;fontColor=#334155;fontSize=11;" vertex="1" parent="1"><mxGeometry x="582" y="700" width="232" height="56" as="geometry"/></mxCell>
