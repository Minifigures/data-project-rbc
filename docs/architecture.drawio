        <mxCell id="api" value="FastAPI service" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#1463B0;fontColor=#0B2545;fontSize=12;" vertex="1" parent="1"><mxGeometry x="470" y="910" width="170" height="72" as="geometry"/></mxCell>
