# Copy to .env and fill in as needed. .env is gitignored and must never be committed.

# Optional: enables the LLM document-perception + rationale layer.
# If unset, ClaimGuard runs fully without any LLM (scoring is unaffected either way).
ANTHROPIC_API_KEY=

# Optional: AWS / LocalStack endpoint for the S3 + DynamoDB integration.
# Leave AWS_ENDPOINT_URL blank for real AWS; set to http://localhost:4566 for LocalStack.
AWS_ENDPOINT_URL=
AWS_REGION=ca-central-1
CLAIMGUARD_S3_BUCKET=claimguard-claims-dev
CLAIMGUARD_DDB_TABLE=claimguard-audit-dev

# Optional: enables Kaggle dataset download in the open-source loader.
# If unset, the loader falls back to the synthetic generator automatically.
KAGGLE_USERNAME=
KAGGLE_KEY=
